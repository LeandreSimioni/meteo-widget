<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Barre de statut en haut -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:text="En attente"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:gravity="center"
        android:padding="12dp" />

    <!-- Code de la station Meteociel utilisée pour la température extérieure -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#222222"
        android:padding="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Station :"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/stationCodeInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#777777"
            android:hint="ex: 58304005"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnSaveStation"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:text="Enregistrer"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Zone de log, prend tout l'espace disponible -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111">

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#00FF00"
            android:textIsSelectable="true"
            android:text="(logs)" />

    </ScrollView>

    <!-- Boutons fixes en bas, toujours visibles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#222222"
        android:padding="8dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Démarrer"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnScan"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:text="Scan debug"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnCopyLogs"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Copier logs"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
